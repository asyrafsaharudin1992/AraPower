{
  "rewrites": [
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "share.arapower.hsohealthcare.com"
        }
      ],
      "destination": "https://storage.googleapis.com/arapower-thumbnails/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}